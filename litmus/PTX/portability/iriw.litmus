PTX COHERENCE
{
x=0;
y=0;
P2:r0=0; P2:r1=0;
P3:r2=0; P3:r3=0;
}
 P0@cta 0,gpu 0        | P1@cta 0,gpu 0        | P2@cta 0,gpu 0       | P3@cta 0,gpu 0       ;
 st.relaxed.cta x, 1   | st.relaxed.cta y, 1   | ld.relaxed.cta r0, x | ld.relaxed.cta r2, x ;
                       |                       | ld.relaxed.cta r1, y | ld.relaxed.cta r3, y ;
exists
(P2:r0 = 1 /\ P2:r1 = 0 /\ P3:r2 = 0 /\ P3:r3 = 1)