OPENCL barrier-ordered

{
[x] = 0;
}

P0@wg 0, dev 0 (global int* x) {
 atomic_store_explicit(x, 1, memory_order_relaxed);
 B1: barrier(CLK_GLOBAL_MEM_FENCE);
}

P1@wg 0, dev 0 (global int* x) {
 *x = 2;
 B1: barrier(CLK_GLOBAL_MEM_FENCE);
 int r1 = atomic_load_explicit(x, memory_order_acquire, memory_scope_work_group);
}

forall (1:r1==1)