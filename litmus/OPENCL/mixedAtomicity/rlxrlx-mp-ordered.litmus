OPENCL MP

{
  [x]=0;
  [y]=0;
}

P0@wg 0, dev 0 (global int* x, global atomic_int* y) {
  atomic_store_explicit(x, 1, memory_order_relaxed, memory_scope_work_group);
  atomic_store_explicit(y, 1, memory_order_relaxed, memory_scope_work_group);
}

P1@wg 0, dev 0 (global int* x, global atomic_int* y) {
  while(atomic_load_explicit(y, memory_order_relaxed, memory_scope_work_group) == 0) {}
  int r1 = *x;
}

forall (1:r1==1)