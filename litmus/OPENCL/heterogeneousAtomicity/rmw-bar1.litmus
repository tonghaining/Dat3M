OPENCL Histgram

{
[x] = 0;
}

P0@wg 0, dev 0 (global int* x) {
  *x = 1;
  B1: barrier(CLK_GLOBAL_MEM_FENCE);
  int r0 = atomic_fetch_add_explicit(x, 1, memory_order_relaxed, memory_scope_work_group);
}

P1@wg 0, dev 0 (global int* x) {
  B1: barrier(CLK_GLOBAL_MEM_FENCE);
  int r1 = atomic_fetch_add_explicit(x, 1, memory_order_relaxed, memory_scope_work_group);
}

exists (P0:r0 = 1 /\ P1:r1 = 1)