OPENCL MP

{
  [x]=0;
}

P0@wg 0, dev 0 (global int* x) {
  *x = 1;
  atomic_store_explicit(x, 2, memory_order_relaxed, memory_scope_work_group);
}

P1@wg 0, dev 0 (global int* x) {
  int r0 = *x;
  int r1 = atomic_fetch_add_explicit(x, 1, memory_order_relaxed, memory_scope_work_group);
  int r2 = *x;
}

exists (1:r0=0 /\ 1:r1=0 /\ 1:r2=1)