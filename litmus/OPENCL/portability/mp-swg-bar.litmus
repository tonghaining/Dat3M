OPENCL MP

{
  [x]=0;
  [y]=0;
}

P0@wg 0, dev 0 (global int* x, global atomic_int* y) {
  *x = 1;
  B1: barrier(CLK_GLOBAL_MEM_FENCE);
  atomic_store_explicit(y,1,memory_order_relaxed, memory_scope_work_group);
}

P1@wg 0, dev 0 (global int* x, global atomic_int* y) {
  int r1 = atomic_load_explicit(y,memory_order_relaxed, memory_scope_work_group);
  B1: barrier(CLK_GLOBAL_MEM_FENCE);
  int r2 = *x;
}

~exists (1:r1=1 /\ 1:r2=0)